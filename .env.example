# ── Required (bot won't start without these) ──────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here   # @BotFather
ANTHROPIC_API_KEY=your_anthropic_api_key_here      # console.anthropic.com

# Supabase — Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here    # service_role key (NOT anon)

# ── AI providers ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here            # platform.openai.com — cho GPT-4.1/5 agents

# ── Facebook Ads (optional — cần cho ads_analytics + ads_optimizer) ──
FB_ACCESS_TOKEN=your_fb_access_token               # User token: permissions ads_read + ads_management + read_insights
FB_AD_ACCOUNT_ID=act_XXXXXXXXXX                    # Ad Account ID — Business Manager → Ad Accounts
FB_APP_ID=your_fb_app_id                           # Developers → Your App → App ID
FB_APP_SECRET=your_fb_app_secret                   # Developers → Your App → App Secret

# ── Ads Scheduler — FB OAuth per-user ─────────────────────────────
# Tạo key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here                # Required cho /connect_ads (mã hóa token FB)

# ── Admin ─────────────────────────────────────────────────────────
ADMIN_IDS=123456789                                # Telegram user IDs (phân cách dấu phẩy) — truy cập /addquota, /userinfo

# ── AI providers (optional) ───────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here            # Google AI Studio — multi-provider fallback

# ── Test mode (optional) ───────────────────────────────────────────
# Force MỌI task type chạy bằng 1 provider rẻ trước (vẫn fallback về routing
# table gốc nếu provider này fail). Để test nhanh, tránh chi phí cao.
# Giá trị hợp lệ: anthropic_haiku, gemini_flash, openai_gpt5_nano, openai_gpt4o_mini, ...
# Bỏ trống / xoá biến này để dùng routing table mặc định.
LLM_FORCE_PROVIDER=openai_gpt5_nano

# ── Deploy (Railway production only — leave blank for local) ──────
WEBHOOK_URL=https://your-app.up.railway.app        # Railway public domain, no trailing slash
PORT=8000                                           # Railway sets this automatically

# ── Database v2 migration flags (default False — do NOT change unless migrating) ──
# DB_V2_WRITE=false
# DB_V2_READ=false
